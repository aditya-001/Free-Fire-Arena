PORT=5000
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=<generate_a_long_random_secret>
CLIENT_URL=https://app.example.com
CLIENT_URLS=https://app.example.com,https://www.app.example.com
TRUST_PROXY=true
ADMIN_SECRET_KEY=<set_a_long_random_admin_bootstrap_key>
LOG_LEVEL=info
TOURNAMENT_LIVE_WINDOW_MINUTES=120
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=40
WALLET_RATE_LIMIT_MAX=120
RAZORPAY_KEY_ID=<your_razorpay_key_id>
RAZORPAY_KEY_SECRET=<your_razorpay_key_secret>
RAZORPAY_CURRENCY=INR
WALLET_MIN_WITHDRAW_AMOUNT=100
FRAUD_AMOUNT_THRESHOLD=25000
